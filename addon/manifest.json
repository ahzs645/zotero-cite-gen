{
  "manifest_version": 2,
  "name": "Zotero Citation Generator",
  "version": "1.0.5",
  "description": "Import AI-generated citations from JSON, verify via DOI, and map reasoning into Zotero notes",
  "homepage_url": "https://github.com/ahmadjalil/zotero-cite-gen",
  "author": "Ahmad Jalil",
  "icons": {
    "48": "content/icons/favicon.svg",
    "96": "content/icons/favicon.svg"
  },
  "applications": {
    "zotero": {
      "id": "cite-gen@zotero.org",
      "update_url": "https://github.com/ahmadjalil/zotero-cite-gen/releases/latest/download/updates.json",
      "strict_min_version": "6.999",
      "strict_max_version": "8.*"
    }
  }
}
